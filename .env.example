# Copy this file to .env and adjust values for your environment.
# .env is gitignored — never commit real secrets.

# Postgres — POSTGRES_HOST/PORT match the docker-compose "postgres" service.
# The backend computes its connection string from these (see
# src/core/config.py Settings.POSTGRES_URL), so there's a single source of
# truth for credentials instead of a separately hand-written DATABASE_URL.
POSTGRES_USER=onecrawler
POSTGRES_PASSWORD=onecrawler
POSTGRES_DB=onecrawler
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

REDIS_URL=redis://redis:6379/0

# Root logging level for the API and worker processes (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Auth — generate a real random value for JWT_SECRET_KEY outside of local dev,
# e.g. `python -c "import secrets; print(secrets.token_urlsafe(64))"`
JWT_SECRET_KEY=dev-secret-change-me-before-deploying
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Seeded on API startup if no user with this email exists yet.
DEFAULT_ADMIN_NAME=Shaun
DEFAULT_ADMIN_EMAIL=sayedshaun4@gmail.com
DEFAULT_ADMIN_PASSWORD=shaun@crawler

# CORS — JSON array of allowed origins
CORS_ORIGINS=["http://localhost:5173"]

# Host-side ports docker-compose publishes containers on (only relevant if
# the default clashes with something else already running on your machine).
# These do not affect in-network communication between containers.
# POSTGRES_HOST_PORT=5433
# REDIS_HOST_PORT=6379
# API_HOST_PORT=8000
